# Google OAuth credentials — both values are required by Dayboard's current token exchange.
# Keep real values only in .env. Do not remove CLIENT_SECRET from the OAuth flow during audits
# unless a tested native/backend exchange replaces the current Google OAuth client setup.
# This is a Google OAuth desktop client. Its loopback callback is handled locally
# by the packaged app and does not need an Authorized redirect URI in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_client_secret_here
